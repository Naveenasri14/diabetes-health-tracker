# create_reminder.py
import os
import django
from datetime import datetime, timedelta

os.environ.setdefault('DJANGO_SETTINGS_MODULE', 'diabetes_tracker.settings')
django.setup()

from tracker.models import Reminder
from django.contrib.auth.models import User

# CHANGE THIS TO YOUR ACTUAL USERNAME!
your_username = 'sujatha_07'

try:
    # Get the user
    user = User.objects.get(username=your_username)
    print(f"✅ Found user: {user.username}")
    
    # Calculate time 2 minutes from now
    now = datetime.now()
    two_minutes_later = now + timedelta(minutes=2)
    
    print(f"⏰ Current time: {now.strftime('%H:%M:%S')}")
    print(f"⏰ Reminder will trigger at: {two_minutes_later.strftime('%H:%M:%S')}")
    
    # Create the reminder
    reminder = Reminder.objects.create(
        user=user,
        reminder_type='glucose_test',
        title='🔥 TEST - 2 MINUTE REMINDER',
        description='This will trigger in 2 minutes',
        frequency='once',
        reminder_time=two_minutes_later.time(),
        start_date=now.date(),
        specific_date=now.date(),
        is_active=True,
        notify_in_app=True,
        notify_email=True,
        notify_sms=False,
        notify_whatsapp=False,
        override_quiet_hours=True,
    )
    
    print("\n" + "="*50)
    print("✅ REMINDER CREATED SUCCESSFULLY!")
    print("="*50)
    print(f"ID: {reminder.id}")
    print(f"Title: {reminder.title}")
    print(f"Time: {reminder.reminder_time}")
    print(f"Date: {reminder.start_date}")
    print("="*50)
    print("\n⏰ WAIT 2 MINUTES, THEN RUN: python3 manage.py send_reminders")
    
except User.DoesNotExist:
    print(f"\n❌ User '{your_username}' not found!")
    print("\nAvailable users:")
    for u in User.objects.all():
        print(f"  - {u.username}")
except Exception as e:
    print(f"\n❌ Error: {e}")
